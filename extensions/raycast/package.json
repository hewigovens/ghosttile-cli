{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ghosttile",
  "title": "GhostTile",
  "description": "Manage GhostTile apps from Raycast.",
  "icon": "assets/icon.png",
  "author": "hewig",
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Developer Tools",
    "Productivity"
  ],
  "preferences": [
    {
      "name": "ghosttilePath",
      "type": "textfield",
      "title": "GhostTile Binary Path",
      "description": "Optional absolute path to the ghosttile CLI.",
      "required": false,
      "placeholder": "/usr/local/bin/ghosttile"
    }
  ],
  "commands": [
    {
      "name": "ghosttile-apps",
      "title": "GhostTile Apps",
      "subtitle": "GhostTile",
      "description": "Manage hidden and running apps with GhostTile.",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.9"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "typecheck": "tsc --noEmit"
  }
}
